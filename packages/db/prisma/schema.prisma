generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  importFileExtension = "ts"
}

generator zod {
  provider              = "prisma-zod-generator"
  output                = "../../zod/generated"
  dateTimeStrategy      = "coerce"
  optionalFieldBehavior = "optional"
  useMultipleFiles      = "false"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  uuid                 String            @id @default(uuid()) @db.Uuid
  first_name           String
  last_name            String
  date_of_birth        DateTime          @db.Date
  department           Department
  start_date           DateTime          @db.Date
  supervisor           String
  phone_number         String
  personal_email       String
  corporate_email      String
  position             Position
  avatar               String?
  avatar_supabase_path String?
  account              Account?
  activities           Activity[]
  contentLocks         ContentEditLock[]
  favoriteContents     FavoriteContent[]
  submittedClaims      InsuranceClaim[]
  contentHits          ContentHit[]
}

model Content {
  uuid               String                   @id @default(uuid()) @db.Uuid
  title              String
  url                String
  content_owner      String
  last_modified_time DateTime                 @db.Timestamp(6)
  expiration_time    DateTime                 @db.Timestamp(6)
  content_type       ContentType
  status             ContentStatus
  for_position       Position
  supabasePath       String?
  file_type          String?
  editLock           ContentEditLock?
  favoritedBy        FavoriteContent[]
  tagAssignments     ContentTagAssignment[]
  claimAssignments   ClaimContentAssignment[]
  contentHits        ContentHit[]
}

model InsuranceClaim {
  uuid                  String                   @id @default(uuid()) @db.Uuid
  requestorEmployeeUuid String                   @db.Uuid
  incident_date         DateTime                 @db.Date
  claim_type            InsuranceClaimType
  incident_description  String
  status                InsuranceClaimStatus     @default(PENDING)
  createdAt             DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                 @updatedAt @db.Timestamp(6)
  requestor             Employee                 @relation(fields: [requestorEmployeeUuid], references: [uuid])
  contents              ClaimContentAssignment[]
}

model ClaimContentAssignment {
  claimUuid   String         @db.Uuid
  contentUuid String         @db.Uuid
  createdAt   DateTime       @default(now())
  claim       InsuranceClaim @relation(fields: [claimUuid], references: [uuid], onDelete: Cascade)
  content     Content        @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)

  @@id([claimUuid, contentUuid])
  @@index([contentUuid])
}

model FavoriteContent {
  employeeUuid String   @db.Uuid
  contentUuid  String   @db.Uuid
  createdAt    DateTime @default(now())
  content      Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeUuid], references: [uuid], onDelete: Cascade)

  @@id([employeeUuid, contentUuid])
  @@index([contentUuid])
}

model ContentEditLock {
  contentUuid     String   @id @db.Uuid
  lockedByEmpUuid String   @db.Uuid
  lockedAt        DateTime @default(now()) @db.Timestamp(6)
  content         Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  lockedByEmp     Employee @relation(fields: [lockedByEmpUuid], references: [uuid], onDelete: Cascade)
}

model ContentTag {
  uuid           String                 @id @default(uuid()) @db.Uuid
  name           String
  normalizedName String                 @unique
  createdAt      DateTime               @default(now())
  assignments    ContentTagAssignment[]
}

model ContentTagAssignment {
  contentUuid String     @db.Uuid
  tagUuid     String     @db.Uuid
  createdAt   DateTime   @default(now())
  content     Content    @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  tag         ContentTag @relation(fields: [tagUuid], references: [uuid], onDelete: Cascade)

  @@id([contentUuid, tagUuid])
  @@index([tagUuid])
}

model Account {
  employeeUuid String           @unique @db.Uuid
  username     String           @id @unique
  password     String
  employee     Employee         @relation(fields: [employeeUuid], references: [uuid])
  settings     AccountSettings?
}

model AccountSettings {
  accountUsername String  @id
  dark_mode       Boolean @default(false)
  account         Account @relation(fields: [accountUsername], references: [username], onDelete: Cascade)
}

model Activity {
  uuid         String        @id @default(uuid()) @db.Uuid
  employeeUuid String        @db.Uuid
  action       ActionType
  resource     ResourceType?
  resourceUuid String?       @db.Uuid
  resourceName String?
  timestamp    DateTime      @default(now()) @db.Timestamp(6)
  employee     Employee      @relation(fields: [employeeUuid], references: [uuid])
}

model ContentHit {
  uuid         String   @id @default(uuid()) @db.Uuid
  contentUuid  String   @db.Uuid
  employeeUuid String   @db.Uuid
  action       HitType
  timestamp    DateTime @default(now()) @db.Timestamp(6)
  content      Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeUuid], references: [uuid])
}

enum Department {
  OPERATION_TECHNOLOGY
  ACCOUNTING
}

enum Position {
  UNDERWRITER
  BUSINESS_ANALYST
  ADMIN
  ACTUARIAL_ANALYST
  EXL_OPERATIONS
  BUSINESS_OP_RATING
}

enum ContentType {
  REFERENCE
  WORKFLOW
}

enum ContentStatus {
  AVAILABLE
  IN_USE
  UNAVAILABLE
}

enum ActionType {
  LOG_IN
  LOG_OUT
  CREATE_CONTENT
  EDIT_CONTENT
  DELETE_CONTENT
  CREATE_CLAIM
  EDIT_CLAIM
  DELETE_CLAIM
  CREATE_EMPLOYEE
  EDIT_EMPLOYEE
  DELETE_EMPLOYEE
  CHECK_OUT_CONTENT
  CHECK_IN_CONTENT
  OWNERSHIP_CHANGE
}

enum ResourceType {
  EMPLOYEE
  CONTENT
  INSURANCE_CLAIM
}

enum InsuranceClaimType {
  HOME
  AUTO
  BUSINESS
}

enum InsuranceClaimStatus {
  PENDING
  UNDER_REVIEW
}

enum HitType {
  SEARCH
  VIEW
  ACCESS
}
