generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  importFileExtension = "ts"
}

generator zod {
  provider              = "prisma-zod-generator"
  output                = "../../zod/generated"
  dateTimeStrategy      = "coerce"
  optionalFieldBehavior = "optional"
  useMultipleFiles      = "false"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  uuid               String            @id @default(uuid()) @db.Uuid
  firstName          String            @map("first_name")
  lastName           String            @map("last_name")
  dateOfBirth        DateTime          @map("date_of_birth") @db.Date
  department         Department
  startDate          DateTime          @map("start_date") @db.Date
  supervisor         String
  phoneNumber        String            @map("phone_number")
  personalEmail      String            @map("personal_email")
  corporateEmail     String            @map("corporate_email")
  position           Position
  avatar             String?
  avatarSupabasePath String?           @map("avatar_supabase_path")
  account            Account?
  activities         Activity[]
  contentLocks       ContentEditLock[]
  contentHits        ContentHit[]
  favoriteContents   FavoriteContent[]
  submittedClaims    InsuranceClaim[]
}

model Content {
  uuid             String                   @id @default(uuid()) @db.Uuid
  title            String
  url              String
  contentOwner     String                   @map("content_owner")
  lastModifiedTime DateTime                 @map("last_modified_time") @db.Timestamptz(6)
  expirationTime   DateTime                 @map("expiration_time") @db.Timestamptz(6)
  contentType      ContentType              @map("content_type")
  status           ContentStatus
  forPosition      Position                 @map("for_position")
  /// Private Supabase object path for uploaded files; external URL content leaves this null.
  supabasePath     String?                  @map("supabase_path")
  fileType         String?                  @map("file_type")
  /// AI/extracted keywords used by the backend full-text search route.
  searchText       String?                  @map("search_text") @db.Text
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  claimAssignments ClaimContentAssignment[]
  editLock         ContentEditLock?
  contentHits      ContentHit[]
  tagAssignments   ContentTagAssignment[]
  favoritedBy      FavoriteContent[]
}

model InsuranceClaim {
  uuid                  String                   @id @default(uuid()) @db.Uuid
  requestorEmployeeUuid String                   @map("requestor_employee_uuid") @db.Uuid
  incidentDate          DateTime                 @map("incident_date") @db.Date
  claimType             InsuranceClaimType       @map("claim_type")
  incidentDescription   String                   @map("incident_description")
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  status                InsuranceClaimStatus     @default(PENDING)
  contents              ClaimContentAssignment[]
  requestor             Employee                 @relation(fields: [requestorEmployeeUuid], references: [uuid])
  comment               String?
}

model ClaimContentAssignment {
  claimUuid   String         @map("claim_uuid") @db.Uuid
  contentUuid String         @map("content_uuid") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  claim       InsuranceClaim @relation(fields: [claimUuid], references: [uuid], onDelete: Cascade)
  content     Content        @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)

  @@id([claimUuid, contentUuid])
  @@index([contentUuid])
}

model FavoriteContent {
  employeeUuid String   @map("employee_uuid") @db.Uuid
  contentUuid  String   @map("content_uuid") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  content      Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeUuid], references: [uuid], onDelete: Cascade)

  @@id([employeeUuid, contentUuid])
  @@index([contentUuid])
}

model ContentEditLock {
  /// One row per content item means the database enforces a single active checkout.
  contentUuid     String   @id @map("content_uuid") @db.Uuid
  lockedByEmpUuid String   @map("locked_by_emp_uuid") @db.Uuid
  lockedAt        DateTime @default(now()) @map("locked_at") @db.Timestamptz(6)
  content         Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  lockedByEmp     Employee @relation(fields: [lockedByEmpUuid], references: [uuid], onDelete: Cascade)
}

model ContentTag {
  uuid           String                 @id @default(uuid()) @db.Uuid
  name           String
  normalizedName String                 @unique @map("normalized_name")
  createdAt      DateTime               @default(now()) @map("created_at")
  assignments    ContentTagAssignment[]
}

model ContentTagAssignment {
  contentUuid String     @map("content_uuid") @db.Uuid
  tagUuid     String     @map("tag_uuid") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  content     Content    @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  tag         ContentTag @relation(fields: [tagUuid], references: [uuid], onDelete: Cascade)

  @@id([contentUuid, tagUuid])
  @@index([tagUuid])
}

model Account {
  employeeUuid String           @unique @map("employee_uuid") @db.Uuid
  username     String           @id @unique
  password     String
  employee     Employee         @relation(fields: [employeeUuid], references: [uuid])
  settings     AccountSettings?
}

model AccountSettings {
  accountUsername String  @id @map("account_username")
  darkMode        Boolean @default(false) @map("dark_mode")
  tutorialDone    Boolean @default(false) @map("tutorial_done")
  account         Account @relation(fields: [accountUsername], references: [username], onDelete: Cascade)
}

model Activity {
  uuid         String        @id @default(uuid()) @db.Uuid
  employeeUuid String        @map("employee_uuid") @db.Uuid
  action       ActionType
  resource     ResourceType?
  resourceUuid String?       @map("resource_uuid") @db.Uuid
  resourceName String?       @map("resource_name")
  timestamp    DateTime      @default(now()) @db.Timestamptz(6)
  employee     Employee      @relation(fields: [employeeUuid], references: [uuid])
}

model ContentHit {
  uuid         String   @id @default(uuid()) @db.Uuid
  contentUuid  String   @map("content_uuid") @db.Uuid
  employeeUuid String   @map("employee_uuid") @db.Uuid
  /// Distinguishes passive views from edit checkout/access events for dashboard stats.
  action       HitType
  timestamp    DateTime @default(now()) @db.Timestamptz(6)
  content      Content  @relation(fields: [contentUuid], references: [uuid], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeUuid], references: [uuid])
}

enum Department {
  OPERATION_TECHNOLOGY
  ACCOUNTING
}

enum Position {
  UNDERWRITER
  BUSINESS_ANALYST
  ADMIN
  ACTUARIAL_ANALYST
  EXL_OPERATIONS
  BUSINESS_OP_RATING
}

enum ContentType {
  REFERENCE
  WORKFLOW
}

enum ContentStatus {
  AVAILABLE
  IN_USE
  UNAVAILABLE
}

enum ActionType {
  LOG_IN
  LOG_OUT
  CREATE_CONTENT
  EDIT_CONTENT
  DELETE_CONTENT
  CREATE_EMPLOYEE
  EDIT_EMPLOYEE
  DELETE_EMPLOYEE
  CHECK_OUT_CONTENT
  CHECK_IN_CONTENT
  OWNERSHIP_CHANGE
  CREATE_CLAIM
  EDIT_CLAIM
  DELETE_CLAIM
}

enum ResourceType {
  EMPLOYEE
  CONTENT
  INSURANCE_CLAIM
}

enum InsuranceClaimType {
  HOME
  AUTO
  BUSINESS
}

enum InsuranceClaimStatus {
  PENDING
  UNDER_REVIEW
  FINISHED
}

enum HitType {
  SEARCH
  VIEW
  ACCESS
}
