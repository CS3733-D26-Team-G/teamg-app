{
  "name": "teamg-app",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/frontend/src/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter frontend exec eslint --fix",
      "pnpm --filter frontend exec prettier --write"
    ],
    "apps/backend/src/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter backend exec eslint --fix",
      "pnpm --filter backend exec prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": []
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "devDependencies": {
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.8.0",
    "turbo": "^2.9.8"
  },
  "dependencies": {
    "react-draggable": "^4.5.0"
  }
}
